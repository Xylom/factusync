@page "/pedidos/nuevo"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inject IJSRuntime JS
@using FactuSync.Shared

<MudText Typo="Typo.h5" Class="mb-4 font-weight-bold" Color="Color.Primary">Crear Nuevo Pedido</MudText>

    <MudCard Class="mb-2 pa-2 elevation-1 rounded-lg">
        <MudAutocomplete T="Cliente" Label="Cliente" 
                         Value="clienteSeleccionado" 
                         ValueChanged="OnClienteSeleccionado"
                         SearchFunc="@BuscarClientes"
                         ToStringFunc="@(c => c == null ? "" : $"{c.Codigo} - {c.Nombre}")"
                         ResetValueOnEmptyText="true" CoerceText="true" CoerceValue="true" 
                         Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         Placeholder="Buscar..." />
    </MudCard>

@if (!string.IsNullOrEmpty(pedido.CodigoCliente))
{
    <MudCard Class="mb-3 pa-2 elevation-1 rounded-lg border-l-4 border-solid" Style="border-color: var(--mud-palette-primary); background-color: var(--mud-palette-background-grey);">
        <div class="d-flex justify-space-between align-center mb-1">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="font-weight-bold">@pedido.NombreCliente (@pedido.CodigoCliente)</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Primary" Size="Size.Small" OnClick="@(() => cartOpen = true)">
                <MudBadge Content="@pedido.Lineas.Count" Color="Color.Error" Overlap="true" Bordered="true">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" />
                </MudBadge>
            </MudIconButton>
        </div>
        
        <MudGrid Spacing="1">
            <MudItem xs="4">
                <MudSelect T="string" Label="Serie" Value="@pedido.TIPPCL" ValueChanged="OnSerieChanged" AnchorOrigin="Origin.BottomCenter" Required="true" Dense="true" Margin="Margin.Dense" Variant="Variant.Text">
                    @foreach (var s in seriesDisponibles)
                    {
                        <MudSelectItem Value="@s">S-@s</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="4">
                <MudSelect T="string" @bind-Value="pedido.ALMPCL" Label="Alm." AnchorOrigin="Origin.BottomCenter" Required="true" Dense="true" Margin="Margin.Dense" Variant="Variant.Text">
                    @foreach (var alm in almacenesDisponibles)
                    {
                        <MudSelectItem Value="@alm.Codigo">@alm.Nombre</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="double?" Label="Nº #" Value="@pedido.CODPCL" ReadOnly="true" Margin="Margin.Dense" Variant="Variant.Text" />
            </MudItem>
        </MudGrid>
    </MudCard>

    <div class="pa-2 rounded-lg elevation-1 bg-white mb-4">
        <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold" Color="Color.Primary">Añadir Artículo</MudText>
        <MudGrid Spacing="1" Class="align-end">
            <MudItem xs="12" sm="6">
                <MudAutocomplete T="Articulo" Label="Artículo" @bind-Value="articuloSeleccionado" SearchFunc="@BuscarArticulos" 
                                 ToStringFunc="@(a => a?.DisplayText)" 
                                 ResetValueOnEmptyText="true" CoerceText="true" CoerceValue="true" 
                                 Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudNumericField @bind-Value="cantidadSeleccionada" Label="Cant." Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.001M" />
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudNumericField @bind-Value="descuentoSeleccionado" Label="Dto%" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" Disabled="!agentCanDiscount" />
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudButton EndIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" OnClick="AgregarLinea" Style="height: 40px;">Add</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <!-- Barra Inferior de Total / Carrito (Sticky) -->
    <div style="position: sticky; bottom: 10px; z-index: 100;" class="mt-4">
        <MudPaper Elevation="4" Class="pa-3 rounded-pill bg-primary d-flex justify-space-between align-center text-white" @onclick="@(() => cartOpen = true)" Style="cursor:pointer;">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" />
                <MudText Typo="Typo.button"><b>@pedido.Lineas.Count Ítems</b></MudText>
            </div>
            <div class="d-flex align-center">
                <MudText Typo="Typo.h6" Class="mr-4"><b>€ @pedido.Total.ToString("N2")</b></MudText>
                <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" />
            </div>
        </MudPaper>
    </div>

    <!-- Cajón del Carrito (Cart Mode) -->
    <MudDrawer @bind-Open="@cartOpen" Anchor="Anchor.Bottom" Height="85vh" Elevation="25" Variant="@DrawerVariant.Temporary" 
               Class="rounded-t-xl overflow-hidden" Style="z-index: 3000;">
        
        <div class="pa-4 d-flex align-center border-b" style="background-color: white;">
            <MudText Typo="Typo.h6" Color="Color.Primary"><b>Resumen del Pedido</b></MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => cartOpen = false)" />
        </div>

        <div style="overflow-y: auto; height: calc(100% - 200px);" class="pa-2 px-4 shadow-inner">
            @if (!pedido.Lineas.Any())
            {
                <div class="d-flex flex-column align-center mt-10">
                    <MudIcon Icon="@Icons.Material.Filled.RemoveShoppingCart" Size="Size.Large" Color="Color.Secondary" Style="font-size: 3rem;" />
                    <MudText Align="Align.Center" Class="mt-2" Color="Color.Secondary">El carrito está vacío</MudText>
                </div>
            }
            else
            {
                @foreach (var lin in pedido.Lineas)
                {
                    <div class="d-flex justify-space-between align-center pa-2 border-b">
                        <div style="max-width: 70%;">
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@lin.DESLPC</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@lin.CANLPC x @((lin.PRELPC ?? 0).ToString("N2")) (Dto @lin.DT1LPC%)</MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudText Typo="Typo.body2" Class="mr-2"><b>@((lin.TOTLPC ?? 0).ToString("N2") )</b></MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => EliminarLinea(lin))" />
                        </div>
                    </div>
                }
            }
        </div>

        <div class="pa-4 pt-2 border-t" style="position: absolute; bottom: 0; left: 0; right: 0; background-color: white; padding-bottom: 90px !important;">
            <div class="d-flex justify-space-between mb-2">
                <MudText Typo="Typo.subtitle1">Total con Impuestos:</MudText>
                <MudText Typo="Typo.h6" Color="Color.Primary"><b>€ @pedido.Total.ToString("N2")</b></MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" FullWidth="true" 
                       Class="rounded-pill py-3 font-weight-bold"
                       OnClick="GuardarPedido" Disabled="guardando || !pedido.Lineas.Any()">
                @if(guardando) { 
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/> 
                    <MudText Class="ms-2">Procesando...</MudText> 
                } else { 
                    <MudText>Confirmar y Enviar Pedido</MudText> 
                }
            </MudButton>
        </div>
    </MudDrawer>
}
}


@code {
    [SupplyParameterFromQuery(Name = "codcli")]
    public string? CodigoClienteQuery { get; set; }

    [SupplyParameterFromQuery(Name = "nomcli")]
    public string? NombreClienteQuery { get; set; }

    [SupplyParameterFromQuery(Name = "edit")]
    public bool EditMode { get; set; }

    [SupplyParameterFromQuery(Name = "serie")]
    public string? SerieEdit { get; set; }

    [SupplyParameterFromQuery(Name = "numero")]
    public double? NumeroEdit { get; set; }

    private Pedido pedido = new Pedido { TIPPCL = "1" };
    private Cliente? clienteSeleccionado;
    private Articulo? articuloSeleccionado;
    private decimal cantidadSeleccionada = 1;
    private decimal descuentoSeleccionado = 0;
    private bool agentCanDiscount = true;
    private bool guardando = false;
    private bool cartOpen = false;
    private List<string> seriesDisponibles = new();
    private List<Almacen> almacenesDisponibles = new();
    private Dictionary<string, TaxItem>? taxConfig;

    protected override async Task OnParametersSetAsync()
    {
        // Solo cargar datos si estamos en modo edición y no hemos cargado el pedido aún
        if (EditMode && !string.IsNullOrEmpty(SerieEdit) && NumeroEdit.HasValue && pedido.CODPCL != NumeroEdit)
        {
            await LoadExistingOrder();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            seriesDisponibles = Enumerable.Range(1, 9).Select(i => i.ToString()).ToList();
            almacenesDisponibles = await Http.GetFromJsonAsync<List<Almacen>>("/api/pedidos/almacenes") ?? new List<Almacen>();
            
            GlobalConfig? fullConfig = null;
            try {
                fullConfig = await Http.GetFromJsonAsync<GlobalConfig>("/api/config/global");
                taxConfig = fullConfig?.IvaConfig;
            } catch { }

            // Aplicar Permisos por Agente
            string? s_id = await JS.InvokeAsync<string?>("sessionStorage.getItem", "seller_id");
            if (fullConfig != null && !string.IsNullOrEmpty(s_id))
            {
                if (fullConfig.OrderSettings.PermisosAgentes.TryGetValue(s_id, out var pAgente))
                {
                    agentCanDiscount = pAgente.PermitirDescuentos;
                    pedido.TIPPCL = pAgente.SeriePorDefecto;
                    Console.WriteLine($"[PERMISOS] Aplicada serie {pAgente.SeriePorDefecto} y Dtos={agentCanDiscount} para Agente {s_id}");
                }
                else
                {
                    // Globales si no hay específico
                    agentCanDiscount = fullConfig.OrderSettings.PermitirDescuentos;
                    pedido.TIPPCL = fullConfig.OrderSettings.SeriePorDefecto;
                }
            }

            if (!EditMode)
            {
                // MODO NUEVO
                if (!string.IsNullOrEmpty(CodigoClienteQuery))
                {
                    pedido.CodigoCliente = CodigoClienteQuery;
                    pedido.NombreCliente = NombreClienteQuery ?? "";
                    var clientes = await Http.GetFromJsonAsync<List<Cliente>>($"/api/clientes?busqueda={pedido.CodigoCliente}");
                    var cli = clientes?.FirstOrDefault(c => c.Codigo == pedido.CodigoCliente);
                    if (cli != null) await AplicarCliente(cli);
                }

                if (string.IsNullOrEmpty(pedido.ALMPCL) && almacenesDisponibles.Any())
                    pedido.ALMPCL = almacenesDisponibles.First().Codigo;

                // Solo cargar número si no venimos de edición
                await CargarSiguienteNumero();
            }
        }
        catch (Exception ex)
        { 
            Console.WriteLine($"Error init: {ex.Message}");
        }
    }

    private async Task LoadExistingOrder()
    {
        try
        {
            var pExistente = await Http.GetFromJsonAsync<Pedido>($"/api/pedidos/{SerieEdit}/{NumeroEdit}");
            if (pExistente != null)
            {
                pedido = pExistente;
                // Cargar datos del cliente para la UI
                var clientes = await Http.GetFromJsonAsync<List<Cliente>>($"/api/clientes?busqueda={pedido.CodigoCliente}");
                var cli = clientes?.FirstOrDefault(c => c.Codigo == pedido.CodigoCliente);
                if (cli != null) clienteSeleccionado = cli;
                
                ActualizarTotal();
                StateHasChanged();
                Snackbar.Add($"Pedido {SerieEdit}-{NumeroEdit} cargado para edición", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("No se pudo recuperar el pedido para editar", Severity.Error);
        }
    }

    private async Task<IEnumerable<Cliente>> BuscarClientes(string val, CancellationToken token)
    {
        if (string.IsNullOrEmpty(val) || val.Length < 1) return new List<Cliente>();
        try
        {
            var res = await Http.GetFromJsonAsync<List<Cliente>>($"api/clientes?busqueda={val}", token);
            return res ?? new List<Cliente>();
        }
        catch { return new List<Cliente>(); }
    }

    private async Task OnClienteSeleccionado(Cliente cli)
    {
        if (cli == null) return;
        
        if (pedido.Lineas.Any())
        {
            // Opcional: Confirmar si desea cambiar cliente teniendo líneas
            // Por ahora lo permitimos pero avisamos que la tarifa podría cambiar
            Snackbar.Add("Cambiando cliente. Verifique los precios de las líneas si la tarifa es distinta.", Severity.Info);
        }

        await AplicarCliente(cli);
    }

    private async Task AplicarCliente(Cliente cli)
    {
        clienteSeleccionado = cli;
        pedido.CodigoCliente = cli.Codigo;
        pedido.NombreCliente = cli.Nombre;
        pedido.REQCLI = cli.REQCLI;
        pedido.TARCLI = cli.TARCLI;
        pedido.FOPPCL = cli.FPACLI;
        descuentoSeleccionado = cli.DT1CLI ?? 0;
        
        Console.WriteLine($"Cliente Aplicado: {cli.Nombre} | Tarifa: {cli.TARCLI}");
        StateHasChanged();
    }

    private async Task OnSerieChanged(string nuevaSerie)
    {
        pedido.TIPPCL = nuevaSerie;
        await CargarSiguienteNumero();
    }

    private async Task CargarSiguienteNumero()
    {
        try
        {
            pedido.CODPCL = await Http.GetFromJsonAsync<double>($"api/pedidos/siguiente?serie={pedido.TIPPCL}");
        }
        catch { pedido.CODPCL = 1; }
    }

    private async Task<IEnumerable<Articulo>> BuscarArticulos(string val, CancellationToken token)
    {
        if (string.IsNullOrEmpty(val) || val.Length < 2) return new List<Articulo>();
        
        try
        {
            // Pasamos la tarifa del pedido actual para obtener los precios correctos
            int tar = (int)pedido.TARCLI;
            if (tar == 0) tar = 1; // Default
            
            var res = await Http.GetFromJsonAsync<List<Articulo>>($"api/articulos?busqueda={val}&tarifa={tar}", token);
            return res ?? new List<Articulo>();
        }
        catch (OperationCanceledException) { return new List<Articulo>(); }
        catch (Exception ex)
        {
            Console.WriteLine($"Error buscando artículos: {ex.Message}");
            return new List<Articulo>();
        }
    }

    private void AgregarLinea()
    {
        if (articuloSeleccionado != null && cantidadSeleccionada > 0)
        {
            // Obtener IVA desde config dinámica
            string idxKey = articuloSeleccionado.IvaIndex.ToString();
            decimal ivaPorc = 21; // Default
            if (taxConfig != null && taxConfig.ContainsKey(idxKey))
            {
                ivaPorc = taxConfig[idxKey].IVA;
            }
            
            // Cálculo de base imponible
            decimal baseUnitLin = articuloSeleccionado.PrecioVenta;
            
            if (articuloSeleccionado.PrecioConIva) 
            {
                baseUnitLin = Math.Round(articuloSeleccionado.PrecioVenta / (1 + (ivaPorc / 100)), 2);
            }
            
            decimal totLpc = baseUnitLin * cantidadSeleccionada;
            // Aplicar descuento si existe
            if (descuentoSeleccionado > 0)
            {
                totLpc = totLpc * (1 - (descuentoSeleccionado / 100));
            }

            var nuevaLinea = new PedidoLinea
            {
                ARTLPC = articuloSeleccionado.Codigo,
                DESLPC = articuloSeleccionado.Descripcion,
                CANLPC = cantidadSeleccionada,
                PRELPC = baseUnitLin,
                DT1LPC = (double)descuentoSeleccionado,
                TOTLPC = totLpc,
                IVALPC = (double)ivaPorc,
                IvaIndex = articuloSeleccionado.IvaIndex,
                COSLPC = articuloSeleccionado.PCOART // Guardar el costo en la línea
            };
            
            pedido.Lineas.Add(nuevaLinea);
            articuloSeleccionado = null;
            cantidadSeleccionada = 1;
            descuentoSeleccionado = 0;
            ActualizarTotal();
        }
    }

    private void EliminarLinea(PedidoLinea linea)
    {
        pedido.Lineas.Remove(linea);
        ActualizarTotal();
    }

    private void ActualizarTotal()
    {
        decimal netoAcum = 0;
        decimal ivaAcum = 0;
        decimal reAcum = 0;

        foreach (var l in pedido.Lineas)
        {
            decimal baseLin = l.TOTLPC ?? 0;
            decimal ivaPct = (decimal)(l.IVALPC ?? 0);

            netoAcum += baseLin;
            ivaAcum += Math.Round(baseLin * (ivaPct / 100), 2);
            
            if (pedido.REQCLI == 1 && taxConfig != null)
            {
                string key = l.IvaIndex.ToString();
                if (taxConfig.ContainsKey(key))
                {
                    decimal rePct = taxConfig[key].RE;
                    reAcum += Math.Round(baseLin * (rePct / 100), 2);
                }
            }
        }
        
        pedido.Total = netoAcum + ivaAcum + reAcum;
    }

    private async Task GuardarPedido()
    {
        if (pedido.Lineas.Count == 0)
        {
            Snackbar.Add("Debe añadir al menos un artículo.", Severity.Warning);
            return;
        }

        guardando = true;
        try
        {
            // Asignar Agente Actual para auditoría y filtros
            var s_id = await JS.InvokeAsync<string>("sessionStorage.getItem", "seller_id");
            Console.WriteLine($"[DEBUG] Intentando asignar agente. s_id encontrado: '{s_id}'");
            
            if (!string.IsNullOrEmpty(s_id) && double.TryParse(s_id, System.Globalization.CultureInfo.InvariantCulture, out var agentId))
            {
                pedido.AGEPCL = agentId;
                Console.WriteLine($"[DEBUG] Agente asignado al pedido: {pedido.AGEPCL}");
            }
            else
            {
                Console.WriteLine("[DEBUG] No se pudo obtener seller_id de la sesión");
            }

            var response = await Http.PostAsJsonAsync("/api/pedidos", pedido);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Pedido guardado exitosamente.", Severity.Success);
                NavManager.NavigateTo("/pedidos");
            }
            else
            {
                var serverError = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error: {serverError}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            guardando = false;
        }
    }
}
