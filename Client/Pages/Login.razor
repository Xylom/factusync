@page "/"
@layout LoginLayout
@inject NavigationManager Navigation
@inject HttpClient Http
@inject ISnackbar Snackbar
@using FactuSync.Shared

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center min-vh-100 pa-4" Style="background: linear-gradient(135deg, var(--mud-palette-primary-darken), var(--mud-palette-primary));">
    <MudPaper Elevation="8" Class="pa-8 w-100 rounded-xl" Style="max-width: 400px; background-color: var(--mud-palette-background); position: relative;">
        
        @if (currentMode == ViewMode.Login)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Settings" 
                           Color="Color.Default" 
                           Class="absolute" 
                           Style="top: 8px; right: 8px;"
                           OnClick="() => currentMode = ViewMode.MasterAuth" />

            <div class="d-flex flex-column align-center mb-6">
                <img src="images/logo_icon.png" alt="FactuSync" style="width: 120px; height: 120px; border-radius: 20px;" class="mb-4 elevation-4" />
                <MudText Typo="Typo.h4" Color="Color.Primary" Class="font-weight-bold mb-2">FactuSync</MudText>
                <MudText Typo="Typo.body2" Color="Color.Dark">Accede con tu usuario de Factusol</MudText>
            </div>

            <EditForm Model="loginModel" OnValidSubmit="AttemptLogin">
                <MudTextField @bind-Value="loginModel.Usuario" 
                              Label="Usuario" 
                              Variant="Variant.Outlined" 
                              Class="mb-4"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Person" />
                
                <MudTextField @bind-Value="loginModel.Clave" 
                              Label="Contraseña" 
                              InputType="@claveInputType" 
                              Variant="Variant.Outlined" 
                              Class="mb-6"
                              Adornment="Adornment.End" 
                              AdornmentIcon="@claveInputIcon" 
                              OnAdornmentClick="ToggleShowClave" />

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           FullWidth="true" 
                           Class="rounded-lg py-3 font-weight-bold"
                           Disabled="isLoading">
                    @if(isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">Conectando...</MudText>
                    }
                    else
                    {
                        <text>INICIAR SESIÓN</text>
                    }
                </MudButton>
            </EditForm>
        }
        else if (currentMode == ViewMode.MasterAuth)
        {
            <div class="d-flex flex-column align-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Warning" Size="Size.Large" Class="mb-2" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h5" Color="Color.Dark" Class="font-weight-bold">Autenticación Maestra</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-2 text-muted">Ingrese la contraseña administradora para configurar la base de datos.</MudText>
            </div>

            <EditForm Model="masterAuthModel" OnValidSubmit="ValidateMaster">
                <MudTextField @bind-Value="masterAuthModel.Password" 
                              Label="Contraseña Maestra" 
                              InputType="@masterInputType" 
                              Variant="Variant.Outlined" 
                              Class="mb-6"
                              Adornment="Adornment.End" 
                              AdornmentIcon="@masterInputIcon" 
                              OnAdornmentClick="ToggleShowMaster" />

                <div class="d-flex gap-2">
                    <MudButton OnClick="() => currentMode = ViewMode.Login" 
                               Variant="Variant.Text" 
                               Color="Color.Default" 
                               FullWidth="true" 
                               Class="rounded-lg py-2">
                        Cancelar
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit" 
                               Variant="Variant.Filled" 
                               Color="Color.Secondary" 
                               FullWidth="true" 
                               Class="rounded-lg py-2"
                               Disabled="isLoading">
                        @if(isLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true"/> } else { <text>Validar</text> }
                    </MudButton>
                </div>
            </EditForm>
        }
        else if (currentMode == ViewMode.DbSettings)
        {
            <div class="d-flex flex-column align-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Secondary" Size="Size.Large" Class="mb-2" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h5" Color="Color.Dark" Class="font-weight-bold">Ruta Base de Datos</MudText>
            </div>

            <EditForm Model="dbModel" OnValidSubmit="SaveDbSettings">
                <MudTextField @bind-Value="dbModel.NewPath" 
                              Label="Ruta absoluta al archivo .accdb" 
                              Variant="Variant.Outlined" 
                              Class="mb-2"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Folder" />
                
                <!-- Hint format para explicar limitaciones del navegador web -->
                <MudText Typo="Typo.caption" Class="d-block mb-6 text-muted">
                    Nota: Los navegadores ocultan la ruta real de los archivos. Debes escribir/pegar la ruta completa del servidor como "C:\Ruta\Factusol.accdb".
                </MudText>

                <div class="d-flex flex-column gap-2">
                    <MudButton OnClick="TestConnection" 
                               Variant="Variant.Outlined" 
                               Color="Color.Info" 
                               FullWidth="true" 
                               Class="rounded-lg py-2"
                               Disabled="isLoading || isTesting">
                        @if(isTesting) { <MudProgressCircular Size="Size.Small" Indeterminate="true"/> } else { <text>Probar Conexión</text> }
                    </MudButton>

                    <div class="d-flex gap-2">
                        <MudButton OnClick="() => currentMode = ViewMode.Login" 
                                   Variant="Variant.Text" 
                                   Color="Color.Default" 
                                   FullWidth="true" 
                                   Class="rounded-lg py-2">
                            Volver
                        </MudButton>
                        <MudButton ButtonType="ButtonType.Submit" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Secondary" 
                                   FullWidth="true" 
                                   Class="rounded-lg py-2"
                                   Disabled="isLoading">
                            @if(isLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true"/> } else { <text>Guardar</text> }
                        </MudButton>
                    </div>
                </div>
            </EditForm>
        }

    </MudPaper>
</MudContainer>

<style>
    .min-vh-100 { min-height: 100vh; }
    .absolute { position: absolute; }
    .text-muted { color: gray; }
</style>

@code {
    private enum ViewMode { Login, MasterAuth, DbSettings }
    
    private ViewMode currentMode = ViewMode.Login;
    
    private LoginRequest loginModel = new LoginRequest { Usuario = "xylom", Clave = "2030" };
    private ValidateMasterRequest masterAuthModel = new();
    private UpdateDbRequest dbModel = new();
    
    // Password toggles
    private bool isShowClave = false;
    private InputType claveInputType = InputType.Password;
    private string claveInputIcon = Icons.Material.Filled.VisibilityOff;

    private bool isShowMaster = false;
    private InputType masterInputType = InputType.Password;
    private string masterInputIcon = Icons.Material.Filled.VisibilityOff;

    private bool isLoading = false;
    private bool isTesting = false;

    private class TestResponse { public string Message { get; set; } = ""; }

    private async Task TestConnection()
    {
        isTesting = true;
        try
        {
            var response = await Http.GetAsync("api/settings/test-connection");
            var result = await response.Content.ReadFromJsonAsync<TestResponse>();
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(result?.Message ?? "Conexión exitosa", Severity.Success);
            }
            else
            {
                Snackbar.Add(result?.Message ?? "Error de conexión", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isTesting = false;
        }
    }

    private void ToggleShowClave()
    {
        isShowClave = !isShowClave;
        claveInputIcon = isShowClave ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
        claveInputType = isShowClave ? InputType.Text : InputType.Password;
    }

    private void ToggleShowMaster()
    {
        isShowMaster = !isShowMaster;
        masterInputIcon = isShowMaster ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
        masterInputType = isShowMaster ? InputType.Text : InputType.Password;
    }

    private async Task AttemptLogin()
    {
        if (string.IsNullOrWhiteSpace(loginModel.Usuario) || string.IsNullOrWhiteSpace(loginModel.Clave))
        {
            Snackbar.Add("Debe ingresar usuario y contraseña", Severity.Warning);
            return;
        }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var agente = await response.Content.ReadFromJsonAsync<Agente>();
                Snackbar.Add($"¡Bienvenido {agente?.NOMAGE}!", Severity.Success);
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                Snackbar.Add("Usuario, contraseña incorrecta o acceso web deshabilitado.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error conectando con el servidor", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private class ValidateResponse {
        public string DbPath { get; set; } = string.Empty;
    }

    private async Task ValidateMaster()
    {
        if (string.IsNullOrWhiteSpace(masterAuthModel.Password))
        {
            Snackbar.Add("Ingrese la contraseña maestra", Severity.Warning);
            return;
        }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/settings/validate-master", masterAuthModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ValidateResponse>();
                dbModel.NewPath = result?.DbPath ?? "";
                dbModel.MasterPassword = masterAuthModel.Password; // Preserve to authorize update
                
                masterAuthModel = new(); // reset UI mask
                currentMode = ViewMode.DbSettings;
            }
            else
            {
                Snackbar.Add("Contraseña maestra incorrecta", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error conectando con el servidor", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveDbSettings()
    {
        if (string.IsNullOrWhiteSpace(dbModel.NewPath))
        {
            Snackbar.Add("La ruta no puede estar vacía", Severity.Warning);
            return;
        }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/settings/dbpath", dbModel);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Ruta de base de datos actualizada.", Severity.Success);
                currentMode = ViewMode.Login; // Return to login successfully
            }
            else
            {
                Snackbar.Add("No se pudo guardar la nueva configuración", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error conectando con el servidor", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
