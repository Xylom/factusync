@page "/"
@layout LoginLayout
@inject NavigationManager Navigation
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using FactuSync.Shared
@using System.Text.Json

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center justify-center min-vh-100 pa-4" Style="background-color: #f8f9fa;">
    <div class="w-100" style="max-width: 400px;">
        
        <!-- App Logo & Branding -->
        <div class="d-flex flex-column align-center mb-8">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl mb-4 d-flex align-center justify-center" Style="background-color: #0056b3; width: 64px; height: 64px;">
                <MudIcon Icon="@Icons.Material.Filled.Architecture" Size="Size.Large" Style="color: white;" />
            </MudPaper>
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1" Style="letter-spacing: 2px; color: #1a1c1e;">FACTUSYNC</MudText>
            <MudText Typo="Typo.body2" Style="color: #6c757d;">Gestión Empresarial de Precisión</MudText>
        </div>

        <MudPaper Elevation="0" Class="pa-8 pb-10 rounded-xl border border-solid" Style="background-color: white; border-color: #e9ecef;">
            
            @if (currentMode == ViewMode.Login)
            {
                <MudText Typo="Typo.h5" Class="font-weight-bold mb-1" Style="color: #1a1c1e;">Acceso Seguro</MudText>
                <MudText Typo="Typo.body2" Class="mb-8" Style="color: #6c757d;">Autentíquese con sus credenciales organizacionales.</MudText>

                <EditForm Model="loginModel" OnValidSubmit="AttemptLogin">
                    <MudText Typo="Typo.caption" Class="font-weight-bold mb-1 d-block" Style="color: #6c757d;">USUARIO</MudText>
                    <MudTextField @bind-Value="loginModel.Usuario" 
                                   Placeholder="usuario"
                                   Variant="Variant.Filled" 
                                   DisableUnderLine="true"
                                   Class="mb-6 rounded-lg custom-input"
                                   Adornment="Adornment.Start" 
                                   AdornmentIcon="@Icons.Material.Filled.Person" />
                    
                    <MudText Typo="Typo.caption" Class="font-weight-bold mb-1 d-block" Style="color: #6c757d;">CONTRASEÑA</MudText>
                    <MudTextField @bind-Value="loginModel.Clave" 
                                   Placeholder="••••••••"
                                   InputType="@claveInputType" 
                                   Variant="Variant.Filled" 
                                   DisableUnderLine="true"
                                   Class="mb-4 rounded-lg custom-input"
                                   Adornment="Adornment.End" 
                                   AdornmentIcon="@(isShowClave ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                   OnAdornmentClick="ToggleShowClave" />
                    
                    <div class="d-flex justify-space-between align-center mb-8 w-100">
                        <MudCheckBox T="bool" Label="Recordar dispositivo" Dense="true" Size="Size.Small" Style="color: #6c757d;" />
                        <MudLink Typo="Typo.caption" Class="font-weight-bold" Style="color: #0056b3;">¿Olvidó su contraseña?</MudLink>
                    </div>

                    <MudButton ButtonType="ButtonType.Submit" 
                               Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Size="Size.Large" 
                               FullWidth="true" 
                               Class="rounded-lg py-3 font-weight-bold"
                               Style="background-color: #0056b3; text-transform: none;"
                               Disabled="isLoading">
                        <div class="d-flex align-center justify-center">
                            @if(isLoading)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                <MudText Class="ms-2">Iniciando sesión...</MudText>
                            }
                            else
                            {
                                <MudText Class="mr-2">Entrar</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Small" />
                            }
                        </div>
                    </MudButton>
                </EditForm>
            }
            else if (currentMode == ViewMode.MasterAuth)
            {
                <MudText Typo="Typo.h5" Class="font-weight-bold mb-1" Style="color: #1a1c1e;">Acceso Maestro</MudText>
                <MudText Typo="Typo.body2" Class="mb-8" Style="color: #6c757d;">Se requieren credenciales de admin para la configuración.</MudText>

                <EditForm Model="masterAuthModel" OnValidSubmit="ValidateMaster">
                    <MudTextField @bind-Value="masterAuthModel.Password" 
                                   Label="Contraseña Maestra" 
                                   InputType="@masterInputType" 
                                   Variant="Variant.Outlined" 
                                   Class="mb-6" />

                    <div class="d-flex gap-2">
                        <MudButton OnClick="() => currentMode = ViewMode.Login" Variant="Variant.Text" FullWidth="true" Class="rounded-lg">Cancelar</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="rounded-lg" Disabled="isLoading">
                            @if(isLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true"/> } else { <text>Validar</text> }
                        </MudButton>
                    </div>
                </EditForm>
            }
            else if (currentMode == ViewMode.DbSettings)
            {
                <MudText Typo="Typo.h5" Class="font-weight-bold mb-1" Style="color: #1a1c1e;">Ajustes BD</MudText>
                <MudText Typo="Typo.body2" Class="mb-8" Style="color: #6c757d;">Configure la ruta de su base de datos Factusol.</MudText>

                <EditForm Model="dbModel" OnValidSubmit="SaveDbSettings">
                    <div class="d-flex align-center gap-2 mb-6">
                        <MudTextField @bind-Value="dbModel.NewPath" Label="Ruta BD (.accdb)" Variant="Variant.Outlined" 
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" />
                        
                        <InputFile id="factusol-file-picker" OnChange="OnInputFileChange" hidden accept=".accdb" />
                        <MudIconButton HtmlTag="label"
                                       Color="Color.Info"
                                       Icon="@Icons.Material.Filled.FileOpen"
                                       for="factusol-file-picker">
                        </MudIconButton>
                    </div>
                    
                    <div class="d-flex flex-column gap-2 text-center">
                         <MudButton OnClick="TestConnection" Variant="Variant.Outlined" Color="Color.Info" FullWidth="true" Class="rounded-lg" Disabled="isTesting">
                            @if(isTesting) { <MudProgressCircular Size="Size.Small" Indeterminate="true"/> } else { <text>Probar Conexión</text> }
                        </MudButton>
                        
                        <div class="d-flex gap-2">
                            <MudButton OnClick="() => currentMode = ViewMode.Login" Variant="Variant.Text" FullWidth="true" Class="rounded-lg">Volver</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="rounded-lg" Disabled="isLoading">Guardar</MudButton>
                        </div>
                    </div>
                </EditForm>
            }
        </MudPaper>

        <!-- Footer Links -->
        <div class="mt-6 d-flex justify-center flex-column align-center animate-up">
            <MudPaper Elevation="0" Class="pa-2 px-4 rounded-pill d-flex align-center" Style="background-color: #e9ecef; cursor: pointer;" @onclick="() => currentMode = ViewMode.MasterAuth">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-2" Style="color: #495057;" />
                <MudText Typo="Typo.caption" Style="color: #495057;">Ajustar <span class="font-weight-bold" style="color: #0056b3;">base de datos</span></MudText>
            </MudPaper>
            
            <MudText Typo="Typo.caption" Class="mt-10" Style="color: #adb5bd; letter-spacing: 0.5px;">
                © 2026 FACTUSYNC. TODOS LOS DERECHOS RESERVADOS.
            </MudText>
        </div>
    </div>
</MudContainer>

<style>
    .min-vh-100 { min-height: 100vh; }
    .custom-input { background-color: #e9ecef !important; border: none !important; }
    .custom-input .mud-input-filled.mud-input-underline:after { display: none; }
    .mud-input-filled.mud-input-underline:before { display: none; }
    .animate-up { animation: fadeInUp 0.5s ease-out; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private enum ViewMode { Login, MasterAuth, DbSettings }
    private ViewMode currentMode = ViewMode.Login;
    private LoginRequest loginModel = new LoginRequest { Usuario = "xylom", Clave = "2030" };
    private ValidateMasterRequest masterAuthModel = new();
    private UpdateDbRequest dbModel = new();
    private bool isShowClave = false;
    private bool isShowMaster = false;
    private InputType claveInputType = InputType.Password;
    private InputType masterInputType = InputType.Password;
    private bool isLoading = false;
    private bool isTesting = false;

    private void ToggleShowClave()
    {
        isShowClave = !isShowClave;
        claveInputType = isShowClave ? InputType.Text : InputType.Password;
    }

    private void ToggleShowMaster()
    {
        isShowMaster = !isShowMaster;
        masterInputType = isShowMaster ? InputType.Text : InputType.Password;
    }

    private async Task AttemptLogin()
    {
        if (string.IsNullOrWhiteSpace(loginModel.Usuario) || string.IsNullOrWhiteSpace(loginModel.Clave))
        {
            Snackbar.Add("Username and Password are required", Severity.Warning);
            return;
        }
        isLoading = true;
        try {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
            if (response.IsSuccessStatusCode) {
                var agente = await response.Content.ReadFromJsonAsync<Agente>();
                if (agente != null)
                {
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "seller_name", agente.NOMAGE);
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "seller_id", agente.CODAGE);
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "is_boss", agente.EsJefe ? "1" : "0");
                }
                Navigation.NavigateTo("/dashboard");
            } else {
                Snackbar.Add("Credenciales inválidas", Severity.Error);
            }
        } catch { Snackbar.Add("Error de conexión", Severity.Error); }
        finally { isLoading = false; }
    }

    private async Task ValidateMaster()
    {
        isLoading = true;
        try {
            var response = await Http.PostAsJsonAsync("api/settings/validate-master", masterAuthModel);
            if (response.IsSuccessStatusCode) {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonNode>();
                dbModel.NewPath = result?["dbPath"]?.ToString() ?? "";
                dbModel.MasterPassword = masterAuthModel.Password; // Mantener para el guardado final
                currentMode = ViewMode.DbSettings;
            } else { Snackbar.Add("Contraseña maestra incorrecta", Severity.Error); }
        } catch { Snackbar.Add("Error al validar clave maestra", Severity.Error); } finally { isLoading = false; }
    }

    private async Task SaveDbSettings()
    {
        isLoading = true;
        try {
            var response = await Http.PostAsJsonAsync("api/settings/dbpath", dbModel);
            if (response.IsSuccessStatusCode) { currentMode = ViewMode.Login; }
        } catch { } finally { isLoading = false; }
    }

    private async Task TestConnection()
    {
        isTesting = true;
        try { 
            var response = await Http.GetAsync($"/api/settings/test-connection");
            if(response.IsSuccessStatusCode) {
                var resStr = await response.Content.ReadAsStringAsync();
                Snackbar.Add("Conexión exitosa con Factusol", Severity.Success); 
            } else {
                Snackbar.Add("Error: No se pudo conectar a la base de datos en esa ruta", Severity.Error);
            }
        }
        catch { Snackbar.Add("Error de comunicación con el servidor", Severity.Error); }
        finally { isTesting = false; }
    }

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            dbModel.NewPath = file.Name;
            Snackbar.Add("Seleccionado: " + file.Name + ". Nota: Complete la ruta de la carpeta (ej: C:\\Factusol\\Datos\\...)", Severity.Info, config => { config.VisibleStateDuration = 10000; });
        }
    }
}
