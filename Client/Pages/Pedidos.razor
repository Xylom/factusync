@page "/pedidos"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<MudText Typo="Typo.h5" Class="mb-4 font-weight-bold" Color="Color.Primary">Historial de Mis Pedidos</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-6 rounded-lg">
    Esta sección muestra los pedidos que has generado hoy pendientes de sincronizar con la oficina central.
</MudAlert>

<MudTable Items="pedidos" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="2" Class="rounded-lg" OnRowClick="@VerDetalle" T="Pedido" RowStyle="cursor: pointer;" Loading="cargando">
    <HeaderContent>
        <MudTh>Pedido #</MudTh>
        <MudTh>Fecha</MudTh>
        <MudTh>Cliente</MudTh>
        <MudTh>Total</MudTh>
        <MudTh>Estado</MudTh>
        <MudTh Style="text-align: right;">Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Pedido #">@($"{context.TIPPCL}-{context.CODPCL}")</MudTd>
        <MudTd DataLabel="Fecha">@context.Fecha.ToShortDateString()</MudTd>
        <MudTd DataLabel="Cliente">@context.CNOPCL</MudTd>
        <MudTd DataLabel="Total"><MudText Color="Color.Primary" Class="font-weight-bold">@context.Total.ToString("N2")</MudText></MudTd>
        <MudTd DataLabel="Estado">
            <MudChip T="string" Color="Color.Info" Size="Size.Small">Pendiente</MudChip>
        </MudTd>
        <MudTd DataLabel="Acciones" Style="text-align: right;">
            <div @onclick:stopPropagation="true">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmarEliminar(context))" />
            </div>
        </MudTd>
    </RowTemplate>
</MudTable>

<MudDialog @bind-Visible="_visible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-3"/> Vista Previa Pedido #@_selectedPedido?.CODPCL
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedPedido != null)
        {
            <MudText Class="mb-2"><b>Cliente:</b> @_selectedPedido.CNOPCL</MudText>
            <MudText Class="mb-4"><b>Fecha:</b> @_selectedPedido.Fecha.ToShortDateString()</MudText>
            
            <MudTable Items="_selectedLineas" Dense="true" Hover="true" Breakpoint="Breakpoint.None" Elevation="0" T="PedidoLinea">
                <HeaderContent>
                    <MudTh>Artículo</MudTh>
                    <MudTh>Cant</MudTh>
                    <MudTh>Total</MudTh>
                </HeaderContent>
                <RowTemplate Context="linea">
                    <MudTd>@linea.DESLPC</MudTd>
                    <MudTd>@linea.CANLPC</MudTd>
                    <MudTd>@linea.TOTLPC?.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => _visible = false" Class="px-10">Cerrar</MudButton>
    </DialogActions>
</MudDialog>

<MudMessageBox @ref="mbox" Title="Confirmar Eliminación">
    <MessageContent>
        @if (pedidoAEliminar != null)
        {
            <MudText>¿Estás seguro de que deseas eliminar el pedido #@pedidoAEliminar.TIPPCL-@pedidoAEliminar.CODPCL de <b>@pedidoAEliminar.CNOPCL</b>?</MudText>
        }
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete">Eliminar</MudButton>
    </YesButton>
    <CancelButton>
        <MudButton Variant="Variant.Text">Cancelar</MudButton>
    </CancelButton>
</MudMessageBox>

@code {
    private bool _visible;
    private Pedido? _selectedPedido;
    private Pedido? pedidoAEliminar;
    private MudMessageBox? mbox;
    private List<PedidoLinea> _selectedLineas = new();
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private List<Pedido> pedidos = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPedidos();
    }

    private async Task LoadPedidos()
    {
        cargando = true;
        try
        {
            pedidos = await Http.GetFromJsonAsync<List<Pedido>>("api/pedidos") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task VerDetalle(TableRowClickEventArgs<Pedido> args)
    {
        _selectedPedido = args.Item;
        try 
        {
            _selectedLineas = await Http.GetFromJsonAsync<List<PedidoLinea>>($"api/pedidos/lineas?tip={_selectedPedido.TIPPCL}&cod={_selectedPedido.CODPCL}") ?? new();
            _visible = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task ConfirmarEliminar(Pedido pedido)
    {
        pedidoAEliminar = pedido;
        StateHasChanged();
        
        bool? result = await mbox?.ShowAsync();
        if (result == true)
        {
            await EliminarPedido(pedido);
        }
    }

    private async Task EliminarPedido(Pedido pedido)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/pedidos?serie={pedido.TIPPCL}&numero={pedido.CODPCL}");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Pedido eliminado correctamente", Severity.Success);
                await LoadPedidos();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error al eliminar: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de conexión: {ex.Message}", Severity.Error);
        }
    }
}
