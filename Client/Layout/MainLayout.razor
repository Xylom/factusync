@inherits LayoutComponentBase

<MudThemeProvider Theme="FactuTheme" IsDarkMode="false" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Style="background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(8px); color: var(--mud-palette-primary);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <div class="d-flex align-center ml-3">
            <img src="images/logo_horizontal.png" alt="FactuSync" style="height: 40px;" />
        </div>
        <MudSpacer />
        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">@AvatarLetters</MudAvatar>
    </MudAppBar>
    
    <MudDrawer @bind-Open="@_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always" Class="border-none d-flex flex-column" Style="height: calc(100vh - 64px) !important;">
        <MudDrawerHeader Class="pa-4">
            <MudText Typo="Typo.h6" Class="font-weight-bold">FactuSync</MudText>
        </MudDrawerHeader>
        
        <div class="flex-grow-1 overflow-auto">
            <MudNavMenu Class="mt-2">
                <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard" Class="rounded-lg mx-2 mb-1">Inicio</MudNavLink>
                <MudNavLink Href="/clientes" Icon="@Icons.Material.Filled.PersonSearch" Class="rounded-lg mx-2 mb-1">Clientes</MudNavLink>
                <MudNavLink Href="/pedidos" Icon="@Icons.Material.Filled.Receipt" Class="rounded-lg mx-2 mb-1">Mis Pedidos</MudNavLink>
                <MudNavLink Href="/facturas" Icon="@Icons.Material.Filled.RequestQuote" Class="rounded-lg mx-2 mb-1">Facturas</MudNavLink>
                <MudNavLink Href="/articulos" Icon="@Icons.Material.Filled.Category" Class="rounded-lg mx-2 mb-1">Artículos</MudNavLink>
                
                @if (isBoss)
                {
                    <MudNavLink Href="/configuracion" Icon="@Icons.Material.Filled.AdminPanelSettings" Class="rounded-lg mx-2 mb-1">Configuraciones</MudNavLink>
                    <MudNavLink Href="/terminal" Icon="@Icons.Material.Filled.Terminal" Class="rounded-lg mx-2 mb-1">Terminal Túnel</MudNavLink>
                }
            </MudNavMenu>
        </div>

        <div class="pa-4 mt-auto border-t border-solid pb-20 pb-md-4" style="border-color: #f1f3f5; background-color: #fafafa;">
            <div class="d-flex align-center mb-3">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="mr-3">@AvatarLetters</MudAvatar>
                <div style="overflow: hidden;">
                    <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate" Style="color: #1a237e;">@userName</MudText>
                    <MudText Typo="Typo.caption" Style="color: #78909c;">@(isBoss ? "Administrador" : "Agente Comercial")</MudText>
                </div>
            </div>
            
            <div class="pa-2 rounded-lg" style="background-color: #e3f2fd; border: 1px solid #bbdefb;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color: #0d47a1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@dbName</MudText>
                </div>
            </div>

            <MudButton Href="/" StartIcon="@Icons.Material.Filled.Logout" FullWidth="true" Variant="Variant.Text" Color="Color.Error" Class="mt-4 rounded-lg" Style="text-transform: none; justify-content: flex-start;">Cerrar Sesión</MudButton>
        </div>
    </MudDrawer>

    <MudMainContent Class="mud-background-gray">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-6 pb-16 px-4">
            @Body
        </MudContainer>
    </MudMainContent>

    <!-- Bottom Navigation para Móviles - SOLUCIÓN DEFINITIVA DE CENTRADO -->
    <MudHidden Breakpoint="Breakpoint.SmAndUp">
        <div style="position: fixed; bottom: 0; left: 0; width: 100%; height: 75px; background-color: white; z-index: 2000; display: flex; justify-content: space-evenly; align-items: center; box-shadow: 0 -5px 15px rgba(0,0,0,0.1); border-top-left-radius: 25px; border-top-right-radius: 25px;">
            <MudIconButton Icon="@Icons.Material.Filled.SpaceDashboard" Href="/dashboard" Color="Color.Primary" Size="Size.Medium" />
            <MudIconButton Icon="@Icons.Material.Filled.PeopleAlt" Href="/clientes" Color="Color.Primary" Size="Size.Medium" />
            <MudIconButton Icon="@Icons.Material.Filled.Inventory2" Href="/articulos" Color="Color.Primary" Size="Size.Medium" />
            <MudIconButton Icon="@Icons.Material.Filled.History" Href="/pedidos" Color="Color.Primary" Size="Size.Medium" />
        </div>
    </MudHidden>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool isBoss = false;
    private string userName = "Usuario";
    private string dbName = "Cargando...";

    private string AvatarLetters => !string.IsNullOrEmpty(userName) && userName.Length >= 2 
        ? userName.Substring(0, 2).ToUpper() 
        : (userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U");

    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try {
            var boss = await JS.InvokeAsync<string>("sessionStorage.getItem", "is_boss");
            isBoss = boss == "1";
            
            var name = await JS.InvokeAsync<string>("sessionStorage.getItem", "seller_name");
            if (!string.IsNullOrEmpty(name)) userName = name;

            var info = await Http.GetFromJsonAsync<System.Text.Json.Nodes.JsonNode>("api/config/system-info");
            dbName = info?["dbName"]?.ToString() ?? "Desconocida";
        } catch { }
    }

    private MudTheme FactuTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#0D47A1", // Azul Profesional Profundo
            Secondary = "#00C853", // Verde Esmeralda para acciones
            Tertiary = "#FF6D00", // Naranja para pedidos
            Background = "#F5F7FA", // Gris muy claro limpio
            AppbarBackground = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            Surface = "#FFFFFF",
            TextPrimary = "#1A237E",
            ActionDefault = "#546E7A"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
